# 복사해서 backend/.env 로 사용. 기본값으로도 동작함.
# 외부 API 키 없음 — 완전 로컬 구조.

TOOKTAK_OLLAMA_BASE_URL=http://localhost:11434
TOOKTAK_LLM_MODEL=qwen3:8b
TOOKTAK_EMBED_MODEL=bge-m3
TOOKTAK_TOP_K=4
TOOKTAK_CHUNK_SIZE=800
TOOKTAK_CHUNK_OVERLAP=120

# (선택) PostgreSQL 영속화 — 설정 시 폼·문서 이력 저장 + 대시보드 최근작업 실데이터.
# 미설정이면 메모리로 동작(샘플 표시). 비밀번호 포함이므로 .env 는 커밋 금지.
# TOOKTAK_DB_URL=postgresql+psycopg2://USER:PW@HOST:PORT/DB
# TOOKTAK_DEFAULT_USER_EMAIL=you@example.com
# TOOKTAK_DEFAULT_USER_NAME=홍길동
